# Copy to .env and fill in your real values. The .env file is loaded by
# docker-compose via `env_file:` and by the Python code via python-dotenv.

# --- Reddit API credentials (https://www.reddit.com/prefs/apps) -------------
CLIENT_ID=
CLIENT_SECRET=
REDDIT_USERNAME=
PASSWORD=

# --- Subreddit being moderated ----------------------------------------------
SUBREDDIT=

# --- MongoDB connection URI -------------------------------------------------
# Locally: mongodb://localhost:27017
# Inside docker-compose: mongodb://mongo:27017 (set automatically by compose)
MONGODB=mongodb://mongo:27017

# --- Optional integrations --------------------------------------------------
GEMINI=
WHITELIST_LLM=
MODERATOR1=
CONVERSATION_ID=
