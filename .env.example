# Copy to .env and fill in your real values. The .env file is loaded by
# docker-compose via `env_file:` and by the Python code via python-dotenv.

# --- Reddit API credentials (https://www.reddit.com/prefs/apps) -------------
CLIENT_ID=
CLIENT_SECRET=
REDDIT_USERNAME=
PASSWORD=

# --- Subreddit being moderated ----------------------------------------------
SUBREDDIT=

# --- MongoDB connection URI -------------------------------------------------
# Locally (no docker): mongodb://localhost:27017
# Inside docker-compose: this is overridden to mongodb://host.docker.internal:27017
# in compose so the bot reaches the host-published mongodb container.
MONGODB=mongodb://localhost:27017

# --- Optional integrations --------------------------------------------------
GEMINI=
WHITELIST_LLM=
MODERATOR1=
CONVERSATION_ID=
